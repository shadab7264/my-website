# Set these environment variables before launching a production server.
PORT=3000
ADMIN_EMAIL=skywardcareerandplacementhub@gmail.com
ADMIN_PASSWORD=choose-a-strong-password
JOB_POSTER_EMAIL=recruiter@skywardeducation.com
JOB_POSTER_PASSWORD=choose-a-strong-recruiter-password
SESSION_SECRET=replace-with-a-long-random-string
GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/AKfycbzfN3aa824FMK0qR1boRXmaBUnNeqV1lV0UbxemMhCHF3vZEZo60UPNna2k-VhW8Zy8/exec
GOOGLE_SHEETS_SECRET=replace-with-a-private-sheet-webhook-secret

# SMTP Gmail Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-16-character-app-password
SMTP_FROM="Skyward Career Hub" <your-email@gmail.com>
EMAIL_NOTIFY_ADMIN=true

# Twilio SMS Configuration
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_SMS_FROM=+1234567890
COMPANY_SMS_NUMBER=+919241080063


